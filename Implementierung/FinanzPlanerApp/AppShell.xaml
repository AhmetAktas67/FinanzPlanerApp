<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FinanzPlanerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FinanzPlanerApp.Views"
    Title="FinanzPlanerApp">
   
    <TabBar>

        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
            Title="Ausgaben"
            ContentTemplate="{DataTemplate views:AusgabenPage}" />

        <ShellContent
            Title="Einstellungen"
            ContentTemplate="{DataTemplate views:SettingsPage}" />

    </TabBar>

</Shell>
