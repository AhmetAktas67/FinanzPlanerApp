<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanzPlanerApp.Views.HomePage"
            
             >




    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <!--Oberer Bereich -->
        <Frame Grid.Row="0" CornerRadius="20" Padding="20">

            <VerticalStackLayout Spacing="14">

                <Label
                  Text="Gesamtausgaben Monat" 
                  FontSize="20"
                  FontAttributes="Bold"
                   HorizontalOptions="Center"   
           
                 ></Label>


                <Label
                 Text="0,00 €" 
                  FontSize="34"
                  FontAttributes="Bold"
                   HorizontalOptions="Center"   
           
                 ></Label>

                <ProgressBar
                 Progress="0"
                 HeightRequest="10"
                  >
                    
                </ProgressBar>


            </VerticalStackLayout>

        </Frame>

        <Frame Grid.Row="1" CornerRadius="16" Padding="0">
            <Grid RowDefinitions="Auto,*">
                
                <Grid Grid.Row="0" Padding="12" ColumnDefinitions="Auto,*,Auto">

                    <Label Text="Monat:"
                           FontSize="16"
                           FontAttributes="Bold"></Label>

                    <Picker
                        Grid.Column="1"
                        Title="Monat auswählen"
                        HorizontalOptions="End"
                        WidthRequest="180"
                        SelectedIndex="0">

                        <Picker.Items>
                            <x:String>Juni 2026</x:String>
                         
                        </Picker.Items>

                    </Picker>



                </Grid>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Essen" FontSize="18" />
                            <Label Grid.Column="1" Text="0,00 €" FontSize="18" FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" />

                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Tank" FontSize="18" />
                            <Label Grid.Column="1" Text="0,00 €" FontSize="18" FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" />

                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Einkauf" FontSize="18" />
                            <Label Grid.Column="1" Text="0,00 €" FontSize="18" FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" />

                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label Text="Freizeit" FontSize="18" />
                            <Label Grid.Column="1" Text="0,00 €" FontSize="18" FontAttributes="Bold" />
                        </Grid>

                    </VerticalStackLayout>
                </ScrollView>





            </Grid>
            
            
            
        </Frame>







    </Grid>
    
    
    
    
    
    
    
</ContentPage>