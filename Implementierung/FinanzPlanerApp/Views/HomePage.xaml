<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanzPlanerApp.Views.HomePage"
            
             >




    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <!--Oberer Bereich -->
        <Frame Grid.Row="0" CornerRadius="20" Padding="20">

            <VerticalStackLayout Spacing="14">

                <Label
                  Text="Gesamtausgaben Monat" 
                  
                  FontSize="20"
                  FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   
           
                 ></Label>


                <Label
                 Text="{Binding Summe, StringFormat='{0:0.00} €'}"
                  FontSize="34"
                  FontAttributes="Bold"
                   HorizontalOptions="Center"   
                   x:Name="GbLabel"
                 ></Label>

                <ProgressBar
                 Progress="0"
                 HeightRequest="10"
                  >
                    
                </ProgressBar>


            </VerticalStackLayout>

        </Frame>

        <Frame Grid.Row="1" CornerRadius="16" Padding="0">
            <Grid RowDefinitions="Auto,*">
                
                <Grid Grid.Row="0" Padding="12" ColumnDefinitions="Auto,*,Auto">

                    <Label Text="Monat:"
                           FontSize="16"
                           FontAttributes="Bold"></Label>

                    <Picker
                        Grid.Column="1"
                        Title="Monat auswählen"
                        HorizontalOptions="End"
                        WidthRequest="180"
                        SelectedIndex="0"
                        x:Name="MonatPicker"
                        SelectedIndexChanged="MonatPicker_SelectedIndexChanged">

                       

                    </Picker>



                </Grid>

                <CollectionView
                 x:Name="HomeKategorienCollectionView"
                 Grid.Row="1">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame
                            Margin="0,0,0,12"
                            Padding="14"
                            CornerRadius="16"
                            BorderColor="Black"
                            BackgroundColor="{Binding Farbe}">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label
                                    Text="{Binding Name}"
                                    FontSize="18"
                                    FontAttributes="Bold" />

                                    <Label
                                    Grid.Column="1"
                                    Text="{Binding Summe,StringFormat='{0:0.00} €'}"
                                    FontSize="18"
                                    FontAttributes="Bold" />
                                </Grid>

                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>





            </Grid>
            
            
            
        </Frame>







    </Grid>
    
    
    
    
    
    
    
</ContentPage>