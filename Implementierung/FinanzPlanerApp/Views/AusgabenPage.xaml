<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanzPlanerApp.Views.AusgabenPage"
             >


    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12" >
        <Button Grid.Row="0"
                Text="+"
                HorizontalOptions="EndAndExpand"
                CornerRadius="12"
                x:Name="AusgabeHinzufügen"
                Clicked="AusgabeHinzufügen_Clicked"></Button>

        <CollectionView
        x:Name="AusgabenCollectionView"
         SelectionMode="Single"
         SelectionChanged="AusgabenCollectionView_SelectionChanged"
        Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                   <SwipeView>


                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem
                                  Text="Löschen"
                                 
                                
                                  BackgroundColor="Red"
                                  Invoked="AusgabeLöschen_Invoked" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <VerticalStackLayout Spacing="0">

                        <Grid Padding="14" ColumnDefinitions="*,120">
                            <VerticalStackLayout>
                                <Label Text="{Binding Kategorie.Name}" FontSize="18" />
                                <Label Text="{Binding Beschreibung}" FontSize="13" />
                                <Label Text="{Binding Datum, StringFormat='{0:dd.MM.yyyy}'}" FontSize="12" />
                            </VerticalStackLayout>

                            <Label
                            Grid.Column="1"
                           Text="{Binding Betrag, StringFormat='{0:0.00} €'}"
                            FontSize="18"
                            FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" />

                    </VerticalStackLayout>

                   </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>



</ContentPage>