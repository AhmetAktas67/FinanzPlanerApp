<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanzPlanerApp.Views.AusgabenPage"
             >


    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12" >
        <Button Grid.Row="0"
                Text="+"
                HeightRequest="50"
                WidthRequest="25"
                HorizontalOptions="EndAndExpand"
                CornerRadius="12"></Button>

        <CollectionView
        x:Name="KategorienCollectionView"
        Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="14" ColumnDefinitions="*,Auto">
                            <Label
                            Text="{Binding Name}"
                            FontSize="18" />

                            <Label
                            Grid.Column="1"
                            Text="0,00 €"
                            FontSize="18"
                            FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>



</ContentPage>